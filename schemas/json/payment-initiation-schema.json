{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PaymentInitiation",
  "type": "object",
  "required": [
    "payment_id",
    "customer_id",
    "payment_type",
    "amount",
    "currency"
  ],
  "properties": {
    "payment_id": {
      "type": "string",
      "pattern": "^PMT-[0-9]+$"
    },
    "customer_id": {
      "type": "string",
      "pattern": "^CUST-[0-9]+$"
    },
    "payment_type": {
      "type": "string",
      "enum": [
        "ACH",
        "WIRE",
        "RTP",
        "FEDWIRE",
        "CHIPS"
      ]
    },
    "amount": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "currency": {
      "type": "string",
      "enum": [
        "USD"
      ]
    }
  },
  "additionalProperties": false
}
